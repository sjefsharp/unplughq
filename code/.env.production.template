# UnplugHQ — Production Environment Variables
# ⚠ NEVER commit this file with real values. Copy to .env.production and populate.
#
# Secret generation:
#   AUTH_SECRET:          openssl rand -base64 32
#   ENCRYPTION_MASTER_KEY: openssl rand -hex 32
#   POSTGRES_PASSWORD:    openssl rand -base64 24
#   REDIS_PASSWORD:       openssl rand -base64 24

# ─── Domain ───────────────────────────────────────────────
DOMAIN=app.unplughq.com
ACME_EMAIL=admin@unplughq.com

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=unplughq
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand
POSTGRES_DB=unplughq
DATABASE_URL=postgresql://unplughq:CHANGE_ME@postgres:5432/unplughq

# ─── Redis / Valkey ───────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand
REDIS_URL=redis://:CHANGE_ME@valkey:6379

# ─── Auth.js ──────────────────────────────────────────────
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
AUTH_URL=https://app.unplughq.com

# ─── Encryption (SSH key encryption master key) ──────────
ENCRYPTION_MASTER_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.unplughq.com
NODE_ENV=production
