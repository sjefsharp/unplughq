# UnplugHQ — Environment Variables
# Copy to .env and fill in values for local development

# ─── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://unplughq:unplughq_dev@localhost:5432/unplughq
POSTGRES_USER=unplughq
POSTGRES_PASSWORD=unplughq_dev
POSTGRES_DB=unplughq
POSTGRES_PORT=5432

# ─── Redis / Valkey ───────────────────────────────────────
REDIS_URL=redis://:unplughq_dev_redis@localhost:6379
REDIS_PASSWORD=unplughq_dev_redis
REDIS_PORT=6379

# ─── Auth.js ──────────────────────────────────────────────
AUTH_SECRET=change-me-to-a-random-32-char-string-in-production
AUTH_URL=http://localhost:3000

# ─── Encryption (SSH key encryption master key) ──────────
ENCRYPTION_MASTER_KEY=change-me-to-a-random-32-char-string-in-production

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_PORT=3000
NODE_ENV=development

# ─── Monitoring Agent (on user's VPS) ────────────────────
# AGENT_API_TOKEN — Per-server token issued during provisioning
# AGENT_SERVER_ID — UUID of the server this agent reports for
# AGENT_CONTROL_PLANE_URL — HTTPS URL of the UnplugHQ control plane
# AGENT_INTERVAL_MS — Metrics collection interval (default: 30000)

# ─── CI / Build ──────────────────────────────────────────
# SKIP_ENV_VALIDATION=true  # Set in CI to bypass env checks during build
