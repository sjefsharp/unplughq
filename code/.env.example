# UnplugHQ — Environment Variables
# Copy to .env and fill in values for local development

# PostgreSQL
DATABASE_URL=postgresql://unplughq:unplughq_dev@localhost:5432/unplughq

# Redis / Valkey
REDIS_URL=redis://:unplughq_dev_redis@localhost:6379

# Auth.js
AUTH_SECRET=change-me-to-a-random-32-char-string-in-production
AUTH_URL=http://localhost:3000

# Encryption (SSH key encryption master key)
ENCRYPTION_MASTER_KEY=change-me-to-a-random-32-char-string-in-production

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Flags
NODE_ENV=development

# Skip env validation during build (CI)
# SKIP_ENV_VALIDATION=true
